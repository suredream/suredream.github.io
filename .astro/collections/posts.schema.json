{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "lang": {
      "type": "string",
      "enum": [
        "en",
        "zh"
      ]
    },
    "summary": {
      "type": "string"
    },
    "translation": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "type": {
      "default": "essay",
      "type": "string",
      "enum": [
        "essay",
        "note",
        "project"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "lang"
  ]
}